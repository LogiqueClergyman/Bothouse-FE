          },
          "400": { "description": "ESCROW_NOT_VERIFIED", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "409": { "description": "ROOM_NOT_OPEN or ROOM_FULL", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
