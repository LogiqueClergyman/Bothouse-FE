          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "game_type": { "type": "string" },
                  "buy_in_wei": { "type": "string" },
                  "max_players": { "type": "integer" },
                  "escrow_tx_hash": { "type": "string" }
