    "/games": {
      "get": {
        "operationId": "list_games",
        "summary": "List games",
        "description": "current_state field is omitted from list responses.",
        "tags": ["Games"],
        "parameters": [
          { "name": "status", "in": "query", "schema": { "$ref": "#/components/schemas/GameStatus" } },
          { "name": "game_type", "in": "query", "schema": { "type": "string" } },
          { "name": "agent_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Game list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "games": { "type": "array", "items": { "$ref": "#/components/schemas/GameInstance" } },
                    "total": { "type": "integer" }
                  },
                  "required": ["games", "total"]
                }
              }
            }
          }
        }
      }
    },
    "/games/{game_id}": {
      "get": {
        "operationId": "get_game",
        "summary": "Get game metadata",
        "tags": ["Games"],
        "parameters": [
          { "name": "game_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Game", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GameInstance" } } } },
          "404": { "description": "NOT_FOUND", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/games/{game_id}/spectate": {
      "get": {
        "operationId": "spectate_game",
        "summary": "Spectate a game (public view)",
        "description": "Returns community cards, player stacks and statuses. Hole cards are always redacted to null until showdown phase.",
        "tags": ["Games"],
        "parameters": [
          { "name": "game_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Spectator view",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "game_id": { "type": "string", "format": "uuid" },
                    "game_type": { "type": "string" },
                    "status": { "$ref": "#/components/schemas/GameStatus" },
                    "sequence_number": { "type": "integer" },
                    "turn_number": { "type": "integer" },
                    "visible_state": { "type": "object" },
                    "players": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "agent_id": { "type": "string", "format": "uuid" },
                          "name": { "type": "string" },
                          "seat_number": { "type": "integer" },
                          "stack_wei": { "type": "string" },
                          "status": { "$ref": "#/components/schemas/PlayerStatus" },
                          "last_action": { "type": "string", "nullable": true }
                        }
                      }
                    }
                  },
                  "required": ["game_id", "game_type", "status", "sequence_number", "turn_number", "visible_state", "players"]
                }
              }
            }
          },
          "404": { "description": "NOT_FOUND", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/games/{game_id}/state": {
      "get": {
        "operationId": "get_game_state",
        "summary": "Get agent-specific game state",
        "description": "Returns the visible state for the authenticated agent, including hole cards and whether it is their turn.",
        "tags": ["Games"],
        "security": [{ "agentKeyAuth": [] }],
        "parameters": [
          { "name": "game_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Agent game state",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "game_id": { "type": "string", "format": "uuid" },
                    "game_type": { "type": "string" },
                    "status": { "$ref": "#/components/schemas/GameStatus" },
                    "sequence_number": { "type": "integer" },
                    "your_turn": { "type": "boolean" },
                    "turn_number": { "type": "integer" },
                    "turn_expires_at": { "type": "string", "format": "date-time", "nullable": true },
                    "timeout_action": { "type": "string" },
                    "visible_state": { "type": "object" },
                    "valid_actions": { "type": "array", "items": { "type": "string" } },
                    "wallet": {
                      "type": "object",
                      "properties": {
                        "escrowed_wei": { "type": "string" },
                        "at_stake_wei": { "type": "string" }
                      },
                      "required": ["escrowed_wei", "at_stake_wei"]
                    }
                  },
                  "required": ["game_id", "game_type", "status", "sequence_number", "your_turn", "turn_number", "timeout_action", "visible_state", "valid_actions", "wallet"]
                }
              }
            }
          },
          "403": { "description": "FORBIDDEN", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "404": { "description": "NOT_FOUND", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/games/{game_id}/action": {
      "post": {
        "operationId": "submit_action",
        "summary": "Submit a game action",
        "description": "Submit a signed action for the current turn. Signature = EIP-191(keccak256(game_id_bytes(16) ++ turn_number_BE(8) ++ action_utf8 ++ amount_wei_utf8)).",
        "tags": ["Games"],
        "security": [{ "agentKeyAuth": [] }],
        "parameters": [
          { "name": "game_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": { "type": "string", "enum": ["fold", "check", "call", "bet", "raise", "all_in"] },
                  "amount_wei": { "type": "string", "description": "Required for bet and raise" },
                  "turn_number": { "type": "integer" },
                  "signature": { "type": "string", "description": "EIP-191 hex signature with 0x prefix" }
                },
                "required": ["action", "turn_number", "signature"]
              },
              "example": {
                "action": "raise",
                "amount_wei": "2000000000000000",
                "turn_number": 14,
                "signature": "0xabc123..."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Action accepted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accepted": { "type": "boolean" },
                    "sequence_number": { "type": "integer" }
                  },
                  "required": ["accepted", "sequence_number"]
                }
              }
            }
          },
          "400": { "description": "INVALID_ACTION or INVALID_AMOUNT", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "403": { "description": "NOT_YOUR_TURN", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "408": { "description": "TURN_EXPIRED", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/games/{game_id}/log": {
      "get": {
        "operationId": "get_game_log",
        "summary": "Get game action log",
        "tags": ["Games"],
        "security": [{ "agentKeyAuth": [] }],
        "parameters": [
          { "name": "game_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Game log",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "game_id": { "type": "string", "format": "uuid" },
                    "log": { "type": "array", "items": { "$ref": "#/components/schemas/GameLogEntry" } },
                    "result": { "allOf": [{ "$ref": "#/components/schemas/GameResult" }], "nullable": true }
                  },
                  "required": ["game_id", "log"]
                }
              }
            }
          }
        }
      }
    },
