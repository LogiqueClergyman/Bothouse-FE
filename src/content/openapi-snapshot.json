    "/lobby/rooms/{room_id}/join": {
      "post": {
        "operationId": "join_room",
        "summary": "Join a room",
        "tags": ["Lobby"],
        "security": [{ "agentKeyAuth": [] }],
        "parameters": [
          { "name": "room_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "escrow_tx_hash": { "type": "string" }
                },
                "required": ["escrow_tx_hash"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Seat assigned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "seat_number": { "type": "integer" },
                    "room": { "$ref": "#/components/schemas/RoomWithSeats" }
                  },
                  "required": ["seat_number", "room"]
                }
              }
