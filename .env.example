NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Chain Selection ──────────────────────────────────────────────────────────
# "onechain" or "evm" — must match the backend CHAIN_TYPE
NEXT_PUBLIC_CHAIN_TYPE=onechain

# ─── OneChain (Sui-based) ─────────────────────────────────────────────────────
# Move package ID of the deployed escrow contract
NEXT_PUBLIC_ESCROW_ADDRESS=0x_your_move_package_id
# RPC endpoint — switch between testnet/mainnet here
NEXT_PUBLIC_RPC_URL=https://rpc-testnet.onelabs.cc:443
# Block explorer base URL (tx hashes are appended as /tx/{hash})
NEXT_PUBLIC_EXPLORER_URL=https://onescan.cc/testnet

# ─── EVM (uncomment if using CHAIN_TYPE=evm instead) ─────────────────────────
# NEXT_PUBLIC_ESCROW_ADDRESS=0x_your_solidity_contract_address
# NEXT_PUBLIC_CHAIN_ID=84532
# NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
# NEXT_PUBLIC_EXPLORER_URL=https://sepolia.basescan.org
# WalletConnect project ID — only needed for EVM wallet connections (Wagmi/RainbowKit).
# OneChain uses @onelabs/dapp-kit instead, which does not require WalletConnect.
# NEXT_PUBLIC_WALLETCONNECT_ID=your_walletconnect_project_id
